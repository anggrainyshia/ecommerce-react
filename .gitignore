# ─── Environment / Secrets ────────────────────────────────────
# Never commit real credentials
.env
.env.local
.env.*.local
backend/.env
frontend/.env

# Keep example files (safe templates without real values)
!.env.example
!backend/.env.example
!frontend/.env.example

# ─── Dependencies ─────────────────────────────────────────────
node_modules/
backend/node_modules/
frontend/node_modules/

# ─── Build Outputs ────────────────────────────────────────────
frontend/dist/
frontend/build/
backend/dist/

# ─── Uploaded Files ───────────────────────────────────────────
# Keep the uploads folder but ignore its contents
backend/uploads/*
!backend/uploads/.gitkeep

# ─── Logs ─────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/
backend/logs/

# ─── Docker ───────────────────────────────────────────────────
# Ignore local Docker volume data if ever mounted to a host path
postgres_data/
redis_data/

# ─── OS Files ─────────────────────────────────────────────────
.DS_Store
.DS_Store?
**/.DS_Store
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── Editor / IDE ─────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ─── Claude Code ──────────────────────────────────────────────
# Local settings, memory, and session transcripts
.claude/settings.local.json
.claude/memory/
.claude/projects/

# ─── Misc ─────────────────────────────────────────────────────
*.pem
*.key
*.cert
.cache/
.temp/
.tmp/